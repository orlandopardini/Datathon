iticas-de-privacidade/',policyLinkInDrawer:true,legacyBrowserSupport:true,forcedClassifyEnabled:true,forceManagePreferences:true,managePreferencesEnabled:false,customerId:'Azywv2UOevMfe5TAZ',configId:'ff3a4560-937d-43d3-9264-81461708c95d',mode:'permissive',domains:['passosmagicos.org.br'],iframes:{},disclosedVendorCount:0},{timer:false,analyticsAlways:false,categories:false,rejectAll:false,firstLayerUsage:false,managePreferences:false,canDismissDialog:false},"pt-br",{"buttons":{"accept":"Aceitar","acceptAll":"Aceitar tudo","deny":"Negar","dialog":{"denyAll":{"fr":"Continue sem aceitar"},"openDrawer":{"fr":"Personalize suas escolhas"}},"denyAll":"Rejeitar tudo","managePreferences":"Gerenciar preferências","save":"Salvar","storagePolicy":"Política de Armazenamento de Dados"},"categories":{"ESSENTIAL":{"label":"Essencial","description":"Necessário para habilitar a funcionalidade básica do site. Você não pode desativar os cookies essenciais."},"MARKETING":{"label":"Publicidade direcionada","description":"Usado para fornecer publicidade mais relevante para você e seus interesses. Também pode ser usado para limitar o número de vezes que você vê um anúncio e medir a eficácia das campanhas publicitárias. As redes de publicidade geralmente os colocam com a permissão do operador do site."},"PERSONALIZATION":{"label":"Personalização","description":"Permita que o site se lembre das escolhas que você faz (como seu nome de usuário, idioma ou a região em que você está) e forneça recursos aprimorados e mais pessoais. Por exemplo, um site pode fornecer boletins meteorológicos locais ou notícias de trânsito armazenando dados sobre sua localização geral."},"ANALYTICS":{"label":"Análise de dados","description":"Ajude o operador do site a entender o desempenho do site, como os visitantes interagem com o site e se pode haver problemas técnicos."},"STORAGE":{"label":"Armazenamento","description":"Permite que o site armazene dados localmente em seu dispositivo. Por exemplo, este site pode armazenar dados que lembrarão das suas escolhas anteriores, filtros de pesquisa ou outras informações que permitem que sua experiência ao navegar pelo site seja mais agradável."},"OPT_OUT":{"label":"Não venda ou compartilhe minhas informações pessoais","description":"Ao alternar para a direita e clicar em salvar, você indica que não deseja que vendamos suas informações pessoais ou compartilhemos suas informações pessoais para atividades de publicidade direcionada on-line. Observe que, se você usar computadores ou navegadores diferentes, deverá indicar suas opções novamente em cada computador ou navegador usado para acessar nossos serviços."}},"dialog":{"close":"Feche esta caixa de diálogo","label":"Banner de consentimento de cookies"},"messaging":{"poweredBy":"Desenvolvido por Osano","default":"Este site utiliza tecnologias como cookies para ativar funcionalidades essenciais do site, bem como para %{analytics}, %{personalization} e %{marketing}.","categories":"Você pode alterar as suas configurações quando quiser ou aceitar as configurações padrão.","cookieQuestion":"O que é um cookie?","timer":"Para saber mais, veja o seguinte link:","privacyPolicy":"Política de Privacidade","cookiePolicy":"Política de Cookies","privacyNotice":"Aviso de privacidade","cookieNotice":"Aviso de Cookie","moreDetails":"Mais detalhes","widgetAltText":"Preferências de cookies","usageWhat":"Para melhorar a sua experiência, nós (e nossos parceiros) armazenamos e / ou acessamos informações em seu terminal (cookie ou equivalente) com o seu consentimento para todos os nossos sites e aplicativos, em seus terminais conectados.","usageHow":"Nosso site pode usar esses cookies para:","usageList":"Medir a audiência da publicidade em nosso site, sem traçar um perfil\nExibir anúncios personalizados com base em sua navegação e seu perfil\nPersonalize nosso conteúdo editorial com base em sua navegação\nPermitem que você compartilhe conteúdo em redes sociais ou plataformas presentes em nosso site\nEnvie-lhe publicidade com base na sua localização","viewCookies":"Ver Cookies","closeButton":"Você pode fechar este banner para continuar apenas com os cookies essenciais.","subjectRightsRequest":"Solicitação de direitos do sujeito","doNotSellOrShare":"Não venda ou compartilhe minhas informações pessoais","securityPolicy":"Política de segurança","imprint":"Imprimir","googlePrivacyPolicy":"Política de privacidade do Google"},"disclosure":{"day":"dia","label":"Itens de Armazenamento","none":"Nenhum item de armazenamento","cookie":{"purpose":"Objetivo","expiry":"Validade","name":"Nome","classification":"Classificação","provider":"Provedor"},"dayPlural":"dias","script":{"purpose":"Objetivo","name":"Nome","classification":"Classificação","provider":"Provedor"}},"drawer":{"header":"Preferências de armazenamento","close":"Fechar preferências de cookie","description":"Quando você visita sites, eles podem armazenar ou recuperar dados sobre você usando cookies e tecnologias semelhantes (\"cookies\"). Os cookies podem ser necessários para a funcionalidade básica do site, bem como para outros fins. Você tem a opção de desativar certos tipos de cookies, embora isso possa afetar sua experiência no site."},"aria":{"newWindow":"Abre em uma nova janela","external":"Abre um site externo","externalNewWindow":"Abre um site externo em uma nova janela"},"doNotSell":{"header":"Suas opções de privacidade","description":"Permitimos que determinados parceiros de publicidade on-line coletem informações de nossos serviços por meio de cookies e tecnologias semelhantes para fornecer anúncios mais relevantes para você e nos ajudar com análises relacionadas à publicidade. Isso pode ser considerado \"venda\" ou \"compartilhamento\" para publicidade on-line direcionada de acordo com certas leis. Para desativar esta atividade, use o botão abaixo.","link":"Você pode aprender mais sobre nossas práticas de privacidade revisando nossas políticas:"}},null,nt({usp:Br}))}();var Promise}();
//# sourceMappingURL=osano.js.map