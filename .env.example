# Environment Configuration
ENVIRONMENT=production

# Model Configuration
MODEL_VERSION=3.0
MODEL_TYPE=dropout_risk

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# CORS Configuration (adicionar domínios permitidos)
ALLOWED_ORIGINS=*

# Feature Flags
ENABLE_MONITORING=true
ENABLE_DRIFT_DETECTION=true

# Limites
MAX_PREDICTIONS_PER_REQUEST=100
REQUEST_TIMEOUT_SECONDS=30

# Render-specific (auto-configurado)
# PORT=8000  # Render define automaticamente
